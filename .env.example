# Salin ke .env dan isi nilainya (JANGAN commit .env).
# Di GitHub, set sebagai repository secrets (Settings → Secrets and variables → Actions).

# Token BPS WebAPI (32 karakter) — dipakai data loader saat build.
BPS_API_KEY=

# Kunci Claude API — dipakai modul usulan AI (workflow semesteran usulan-ai.yml).
ANTHROPIC_API_KEY=
